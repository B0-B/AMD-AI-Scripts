# Devices and logging
HIP_VISIBLE_DEVICES=0
AMD_LOG_LEVEL=1
VLLM_LOGGING_DEBUG_LEVEL=DEBUG

# Use AITER optimizations
VLLM_ROCM_USE_AITER=1
VLLM_USE_AITER_TRITON_ROPE=1
VLLM_ROCM_USE_AITER_RMSNORM=1
VLLM_ROCM_USE_AITER_MHA=0

# For CPU inference (otherwise will be ignored)
VLLM_CPU_KVCACHE_SPACE=32 # will use this amount of RAM in GB 
VLLM_CPU_OMP_THREADS_BIND=0-31 # will use up to 32 threads at most

# Quark kernel build - constrain to the architecture being used only
PYTORCH_ROCM_ARCH=gfx942